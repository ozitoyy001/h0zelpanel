# ─── Configuration h0zelpanel ───────────────────────
# Copie ce fichier vers .env puis modifie les valeurs.

# Mot de passe d'accès (OBLIGATOIRE, 12 caractères minimum)
PANEL_PASSWORD=change_moi_minimum_12_caracteres

# Nom du serveur affiché
SERVER_NAME=mon-serveur

# Nom d'utilisateur affiché
PANEL_USER=hozel

# Système d'exploitation (laisse vide pour auto-détection)
OS_NAME=

# Port d'écoute
PANEL_PORT=7777

# (avancé) chemin pm2 si absent du PATH — laisse commenté sinon
# PM2_BIN=/usr/local/bin/pm2

# Trust proxy pour reverse proxy (nginx, etc.)
# TRUST_PROXY=1   # ou "loopback"

# Cookie secure (HTTPS)
# SECURE_COOKIE=1

# Le reste (CPU, RAM, kernel, IP, archi...) est détecté automatiquement
# et affiché dans Paramètres → Spécifications.
